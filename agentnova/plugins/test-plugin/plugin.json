{
  "name": "test-plugin",
  "version": "0.1.0",
  "display_name": "Plugin System Test",
  "description": "Validates the plugin system — discovery, loading, registration, CLI commands, backend, config, and dependencies",
  "author": "Super-Z (GLM-5)",
  "license": "MIT",
  "type": "feature",
  "entrypoint": "__init__",
  "depends": [],
  "optional_depends": [],
  "config": {
    "env_prefix": "TEST_PLUGIN",
    "defaults": {
      "TEST_PLUGIN_VALUE": "hello from plugin",
      "TEST_PLUGIN_NUMBER": "42"
    }
  },
  "provides": {
    "backends": {
      "test-backend": "test_backend.TestBackend"
    },
    "cli_commands": ["plugin-test"],
    "cli_flags": {
      "--backend": ["test-backend"]
    }
  },
  "compatibility": {
    "agentnova": ">=0.5.0"
  }
}
